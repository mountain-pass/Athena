	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>Athena uses the microphone for push-to-talk voice commands.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Athena transcribes your voice on-device to send commands to your agent.</string>
